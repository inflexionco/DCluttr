# DCluttr environment variables
# Copy this to .env and fill in values

# Backend server config
DCLUTTR_HOST=127.0.0.1
DCLUTTR_PORT=8000
DCLUTTR_RELOAD=false

# Data directory (default: ~/.dcluttr)
# DCLUTTR_DATA_DIR=/path/to/custom/data

# Enable SQLAlchemy query logging (dev only)
DCLUTTR_DB_ECHO=false

# OpenAI API key (required for AI rename in Phase 2)
# OPENAI_API_KEY=sk-...

# Ollama endpoint (offline fallback, Phase 2)
# OLLAMA_BASE_URL=http://localhost:11434
