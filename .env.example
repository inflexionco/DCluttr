# NeatDrive environment variables
# Copy this to .env and fill in values

# Backend server config
NEATDRIVE_HOST=127.0.0.1
NEATDRIVE_PORT=8000
NEATDRIVE_RELOAD=false

# Data directory (default: ~/.neatdrive)
# NEATDRIVE_DATA_DIR=/path/to/custom/data

# Enable SQLAlchemy query logging (dev only)
NEATDRIVE_DB_ECHO=false

# OpenAI API key (required for AI rename in Phase 2)
# OPENAI_API_KEY=sk-...

# Ollama endpoint (offline fallback, Phase 2)
# OLLAMA_BASE_URL=http://localhost:11434
